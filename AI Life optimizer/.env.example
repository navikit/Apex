# Copy this file to `.env` and fill in your credentials.

# Database
DATABASE_URL=sqlite:///./data/aio_life_optimizer.db

# External API keys (optional placeholders)
GOOGLE_CALENDAR_API_KEY=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=

# LLM / AI settings (optional)
OPENAI_API_KEY=

# App settings
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
